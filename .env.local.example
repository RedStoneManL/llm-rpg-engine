# Copy this to `.env.local` (gitignored) and fill in your GLM/zai key, then `./run.sh`.
ZHIPU_API_KEY=your-zai-key-here

# Optional overrides (defaults shown):
# GLM_MODEL=glm-5.1
# GLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# GLM_MAX_TOKENS=32768   # per-call OUTPUT cap (reasoning + narration); endpoint accepts >=131072
# GLM_MAX_REPAIRS=6      # validation-repair rounds per turn before dropping bad sections
# CAMPAIGN=./campaign
